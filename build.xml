  <!-- OPTIONAL: SpotBugs static analysis                           -->
  <!-- To enable:                                                   -->
  <!--   1. Download spotbugs-X.Y.Z.zip; extract jars to lib/      -->
  <!--   2. Uncomment the target below                              -->
