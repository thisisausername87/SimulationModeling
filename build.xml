  <!-- OPTIONAL: PMD source code analysis                           -->
  <!-- To enable:                                                   -->
  <!--   1. Download pmd-bin-X.Y.Z.zip; extract jars to lib/       -->
  <!--   2. Uncomment the target below                              -->
  <!-- ============================================================ -->
